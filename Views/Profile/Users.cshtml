@using Blog.Models.Request
@{
    ViewData["Title"] = "Профиль";
}
@model ProfileModel
@{
}
@{
    Layout = "_MainLayout";
}


<!Doctype html>
<html lang="Russian">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/carousel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/gallery.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/follow.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-light.min.css">
</head>
<body>
    

<section>
    <div class="profile-container" data-current-user="@Model.CurrentUserName">

        <div class="profile-info">

            <!-- Аватар -->
            <img src="@(Model.AvatarPath ?? "~/img/Image.png")" class="profile-avatar">

            <!-- Правый блок (всё кроме аватарки) -->
            <div class="profile-main">

                <!-- Верхняя строка: имя + кнопка -->
                <div class="profile-header">

                    <div class="profile-header-left">
                        <div class="profile-name">@Model.UserName</div>
                        <div class="profile-status">
                            @(Model.IsActive ? "В сети" : "Не в сети")
                        </div>
                    </div>

                    <div class="profile-header-right">
                        @if (Model.IsCurrentUser)
                        {
                            <button id="editProfileBtn" class="edit-profile-btn">Редактировать</button>
                        }
                        else
                        {
                            <button class="follow-btn @(Model.IsFollowing ? "following" : "")"
                                    data-user-name="@Model.UserName">
                                @(Model.IsFollowing ? "Отписаться" : "Подписаться")
                            </button>
                        }
                    </div>

                </div>

                <!-- Bio -->
                <div class="profile-bio">
                    @(Model.Bio ?? "Здесь размещается информация о пользователе.")
                </div>

                <!-- Подписки / Подписчики -->
                <div class="profile-follow-stats">
                    <button class="open-followers">
                        <strong>@Model.FollowersCount</strong> Подписчики
                    </button>
                    <button class="open-following">
                        <strong>@Model.FollowingCount</strong> Подписки
                    </button>
                </div>

            </div>
        </div>
        
        @if (Model.IsCurrentUser)
        {
            <!-- твоя модалка редактирования профиля остаётся как есть -->
            <div class="modal" id="modal-edit-profile">
                <div class="modal__overlay"></div>

                <div class="modal__content modal-profile">
                    <button class="modal__close">&times;</button>

                    <h2>Редактировать профиль</h2>
                    <div id="profile-data"
                         data-username="@Model.UserName"
                         data-bio="@Model.Bio"
                         data-avatar="@Model.AvatarPath">
                    </div>

                    <form id="edit-profile-form">

                        <label for="profile-name">Имя:</label>
                        <input type="text" id="profile-name" class="modal-input" required>

                        <label for="profile-about">О себе:</label>
                        <textarea id="profile-about" class="modal-textarea"></textarea>

                        <div class="avatar-wrapper">
                            <label for="profile-avatar-input" class="avatar-upload-area">
                                <div id="profile-avatar-preview" class="profile-avatar-preview"></div>

                                <div class="avatar-overlay">
                                    <span class="camera-icon">📷</span>
                                </div>
                            </label>
                            <button type="button" id="avatar-remove-btn" class="avatar-remove-btn">×</button>
                        </div>
                        <input type="file" id="profile-avatar-input" accept="image/*" hidden>

                        <div class="modal-actions">
                            <button type="submit" class="modal-save-btn">Сохранить</button>
                        </div>
                    </form>

                </div>
            </div>
        }
    </div>
</section>

    



    @if (Model.IsCurrentUser)
    {
        <section>
            <button id="add-publication-button" data-popup-target="add-publication-popup">
                <img src="~/img/Plus.png" class="create-publication-icon">
                <p id="create-publication-title">Добавить пост</p>
            </button>

            <!-- Попап для добавления поста -->
            <div class="modal" id="modal-add-post">
                <div class="modal__overlay"></div>

                <div class="modal__content">
                    <button class="modal__close">&times;</button>

                    <h2>Добавить пост</h2>

                    <form id="add-publication-form" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <label for="image">Изображения (до 4):</label>
                        <input type="file" id="image" name="images" multiple accept="image/*">

                        <div class="images-preview" id="images-preview"></div>

                        <label for="add-publication-title">Заголовок:</label>
                        <input type="text" id="add-publication-title" name="title" required>

                        <label for="add-publication-description">Описание:</label>
                        <textarea id="add-publication-description" name="description" required></textarea>

                        <button type="submit" id="submit-add">Опубликовать</button>
                    </form>
                </div>
            </div>


        </section>
    }

    <section>
        <!-- Карусель с постами пользователя -->
        @if (Model.Posts != null && Model.Posts.Any())
        {
            <div class="carousel">
                <div class="carousel-container">
                    @foreach (var post in Model.Posts.OrderByDescending(p => p.CreatedAt))
                    {
                        if (post.Images != null)
                        {
                            @foreach (var postImage in post.Images.Take(1))
                            {
                                <img src="@postImage" alt="Пост @post.Id" class="carousel-image" data-post-id="@post.Id">
                            }
                        }
                    }
                </div>
                <button class="carousel-button prev" onclick="moveLeft()">&#10094;</button>
                <button class="carousel-button next" onclick="moveRight()">&#10095;</button>
            </div>
        }
    </section>
    
    <div class="container">
        <main role="main" class="pb-3">
            <div class="publication-container" id="posts-container" data-user-name="@Model.UserName">
                
                <div id="posts-sentinel"></div>
            </div>


            @if (Model.IsCurrentUser)
            {
                <!-- Попап редактирования поста -->
                <div class="modal" id="modal-edit-post">
                    <div class="modal__overlay"></div>

                    <div class="modal__content">
                        <button class="modal__close">&times;</button>

                        <h2>Редактировать пост</h2>

                        <form id="edit-post-form">

                            <input type="hidden" id="edit-post-id">

                            <label for="edit-title">Заголовок:</label>
                            <input type="text" id="edit-title" class="modal-input" required>

                            <label for="edit-description">Описание:</label>
                            <textarea id="edit-description" class="modal-textarea" required></textarea>

                            <label for="edit-image-input">Добавить изображения:</label>
                            <input type="file" id="edit-image-input" multiple accept="image/*">

                            <div id="edit-images-preview" class="images-preview"></div>

                            <div class="modal-actions">
                                <button type="button" id="delete-post-btn" class="modal-delete-btn">Удалить</button>
                                <button type="submit" class="modal-save-btn">Сохранить</button>
                            </div>
                        </form>
                    </div>
                </div>




            }

            
            
            <!-- Попап галереи на карусели -->
            <div class="modal" id="modal-photo-view">
                <div class="modal__overlay"></div>

                <div class="modal__content">
                    <button class="modal__close">&times;</button>
                    <img class="photo-view-image" id="photoViewImage" src="" alt="">
                    <button class="photo-view-post-btn" id="photoViewPostBtn">Перейти к посту</button>
                </div>
            </div>
            
            <div class="modal" id="follow-modal">
                <div class="modal__overlay"></div>

                <div class="modal__content follow-modal-content">
                    <button class="modal__close">&times;</button>

                    <div class="follow-tabs">
                        <button class="follow-tab active" data-target="followers">Подписчики</button>
                        <button class="follow-tab" data-target="following">Подписки</button>
                    </div>

                    <div class="follow-content">

                        <div class="followers-container follow-pane active"
                             data-username="@Model.UserName">
                            <div class="followers-list" data-page="1">
                                <div class="followers-sentinel"></div>
                            </div>
                        </div>

                        <div class="following-container follow-pane"
                             data-username="@Model.UserName">
                            <div class="following-list" data-page="1">
                                <div class="following-sentinel"></div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>



        </main>
    </div>

    @section Scripts {
        
        <script>
            var isCurrentUser = @Json.Serialize(Model.IsCurrentUser);
        </script>
        
        
    }
    

</body>
</html>